APP_NAME="InteTeam Support"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Europe/London

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=inteteam_support
DB_USERNAME=support
DB_PASSWORD=SupportDevPass

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=RedisDevPass
REDIS_PORT=6379

# ─── Session / Cache / Queue ──────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="support@inteteam.com"
MAIL_FROM_NAME="${APP_NAME}"
# Production: use port 465/SSL — Contabo blocks 587
# MAIL_PORT=465
# MAIL_ENCRYPTION=ssl

# ─── SSO (inteteam-sso) ───────────────────────────────────────────────────────
SSO_ENABLED=false
SSO_URL=http://localhost:8087
SSO_INTERNAL_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI="${APP_URL}/auth/sso/callback"

# ─── Panel Integration ───────────────────────────────────────────────────────
# Shared secret for Panel → inteteam-support provisioning API calls
PANEL_TOKEN=

# ─── Port (assigned by Panel, injected into .env automatically) ──────────────
PORT=8094

# ─── Reverb (WebSockets) ─────────────────────────────────────────────────────
REVERB_APP_ID=support
REVERB_APP_KEY=support-key
REVERB_APP_SECRET=support-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ─── Knowledge Base (inteteam-rag) ───────────────────────────────────────────
# Base URL of the inteteam-rag service; leave empty to disable KB suggestions silently
RAG_URL=

# ─── Remote Desktop (inteteam-remote) ────────────────────────────────────────
# JWT shared secret — must match JWT_SECRET in inteteam-remote .env
REMOTE_JWT_SECRET=
# HTTP URL for inteteam-support → signaling server API calls (session token issuance)
REMOTE_SIGNALING_URL=http://remote_signaling:8090
# WebSocket URL for engineer browser → signaling server
REMOTE_SIGNALING_WS_URL=wss://remote.inte.team
